# Kaleyra Configuration (Primary SMS provider for India)
# Sign up: https://www.kaleyra.com/signup/
KALEYRA_API_KEY=your_kaleyra_api_key_here
KALEYRA_SID=your_kaleyra_sid_here
KALEYRA_SENDER=KALERA

# App Configuration
APP_URL=http://localhost:3000
PORT=5000
VITE_API_URL=http://localhost:5000/api
