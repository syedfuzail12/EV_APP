# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Twilio Configuration (WhatsApp - Optional, 50 msg/day limit)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_32_character_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# Fast2SMS Configuration (SMS - FREE, 100+ SMS/day for India)
# Get your API key from: https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# App Configuration
APP_URL=http://localhost:3000
PORT=5000
VITE_API_URL=http://localhost:5000/api
