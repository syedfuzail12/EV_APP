# ===================================
# SUPABASE CONFIGURATION (Required)
# ===================================
# Get these from: https://supabase.com/dashboard
SUPABASE_URL=https://wzuhdwojthzrnzibxwlu.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ===================================
# TWILIO WHATSAPP (Required for WhatsApp)
# ===================================
# Create account: https://www.twilio.com/try-twilio
# Get credentials: https://console.twilio.com/
# WhatsApp sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_32_character_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# ===================================
# FAST2SMS (Required for OTP Verification)
# ===================================
# Create account: https://www.fast2sms.com/
# Add credits: Wallet > Add Money (₹100 minimum)
# Get API key: Dev API > Copy Authorization key

FAST2SMS_API_KEY=your_fast2sms_api_key_here
FAST2SMS_SENDER_ID=FSTSMS

# ===================================
# APP CONFIGURATION
# ===================================
# Your deployed app URL (from Vercel)
APP_URL=https://your-app-url.vercel.app

# Backend port (Render auto-assigns 10000)
PORT=5000

# Frontend API URL (for web app to connect to backend)
VITE_API_URL=https://ev-app-frb6.onrender.com/api

# ===================================
# NOTES
# ===================================
# 1. SUPABASE_URL and SUPABASE_KEY: Already configured
# 2. TWILIO variables: Add after creating new Twilio account
# 3. FAST2SMS variables: Add after creating Fast2SMS account (REQUIRED for OTP)
# 4. APP_URL: Your Vercel frontend URL
# 5. VITE_API_URL: Already set to your Render backend
#
# WhatsApp Activation:
# - Create Twilio account: https://www.twilio.com/try-twilio
# - Join WhatsApp sandbox: Send "join [code]" to +14155238886
# - Configure webhook: https://ev-app-frb6.onrender.com/api/whatsapp
# - Add 3 Twilio variables to Render environment
#
# OTP Verification Setup:
# - Create Fast2SMS account: https://www.fast2sms.com/
# - Add credits in Wallet (₹100 = ~500-1000 OTPs)
# - Copy API key from Dev API page
# - Add FAST2SMS_API_KEY to .env
#
# Full guides: ACTIVATE_WHATSAPP_NOW.md, ADD_SECURITY_NOW.md
