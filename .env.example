MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=RDWRRR
# Optional: MSG91_FLOW_ID=your_dlt_template_id (if you have DLT approved template)

# App Configuration
APP_URL=http://localhost:3000
PORT=5000
VITE_API_URL=http://localhost:5000/api
